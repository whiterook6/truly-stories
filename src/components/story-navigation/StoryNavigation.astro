---
import { type Story } from '@/utils/stories';
import './StoryNavigation.css';

interface Props {
  previous: Story | null;
  next: Story | null;
}
const { previous, next } = Astro.props;
---

<nav class="story-nav" aria-label="Story navigation">
  { previous && (
    <a class="story-nav-link story-nav-prev" href={previous.href}>
      <span class="story-nav-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          class="lucide lucide-arrow-left-icon lucide-arrow-left">
          <path d="m12 19-7-7 7-7" />
          <path d="M19 12H5" />
        </svg>
      </span>
      <span class="story-nav-label">Previous: {previous.title}</span>
    </a>
  )}
  { next && (
    <a class="story-nav-link story-nav-next" href={next.href}>
      <span class="story-nav-label">Next: {next.title}</span>
      <span class="story-nav-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          class="lucide lucide-arrow-right-icon lucide-arrow-right">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </span>
    </a>
  )}
</nav>
