---
import { getAuthorsNotesHref, getStoryNeighbors, pathToSlug } from '../utils/stories';
import './StoryFooter.css';

const currentPath = Astro.props.currentPath as string;
const { previous, next } = getStoryNeighbors(currentPath);
const authorsNotesHref = getAuthorsNotesHref(pathToSlug(currentPath));
---

<nav class="story-footer" aria-label="Story navigation">
  <div class="story-footer-nav">
    {
      previous ? (
        <a class="story-footer-btn" href={previous.href}>
          ← { previous.title }
        </a>
      ) : (
        <span class="story-footer-btn is-disabled" aria-disabled="true">
          ← Previous
        </span>
      )
    }
    {
      next ? (
        <a class="story-footer-btn" href={next.href}>
          { next.title } →
        </a>
      ) : (
        <span class="story-footer-btn is-disabled" aria-disabled="true">
          Next →
        </span>
      )
    }
  </div>
  <div class="story-footer-links">
    <a class="story-footer-text-link" href="/">Back to Stories</a>
    {
      authorsNotesHref ? (
        <a class="story-footer-text-link" href={authorsNotesHref}>
          Author's Notes
        </a>
      ) : (
        <span class="story-footer-text-link-placeholder" aria-hidden="true" />
      )
    }
  </div>
</nav>
