---
import { getStoryNeighbors } from '../utils/stories';

const { currentPath } = Astro.props;
const { previous, next } = getStoryNeighbors(currentPath);
---

<nav class="story-footer" aria-label="Story navigation">
  <div class="story-footer-item story-footer-prev">
    {
      previous && (
        <a class="story-footer-link" href={previous.href}>
          ← {previous.title}
        </a>
      )
    }
  </div>
  <div class="story-footer-item story-footer-home">
    <a class="story-footer-link" href="/">
      Back to Stories
    </a>
  </div>
  <div class="story-footer-item story-footer-next">
    {
      next && (
        <a class="story-footer-link" href={next.href}>
          {next.title} →
        </a>
      )
    }
  </div>
</nav>
