---
import '../styles/global.css';

interface StoryTags {
  tone?: string[];
  themes?: string[];
  genre?: string[];
}

interface StoryFrontmatter {
  title: string;
  publishDate: string;
  author?: string;
  tags?: StoryTags;
  downloadUrl?: string;
}

const storyModules = import.meta.glob<{ frontmatter: StoryFrontmatter }>(
  './stories/*.md',
  { eager: true }
);

const storyRawModules = import.meta.glob<string>('./stories/*.md', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const WORDS_PER_MINUTE = 225;

function stripFrontmatter(raw: string): string {
  if (!raw.startsWith('---')) return raw;
  const end = raw.indexOf('\n---', 3);
  if (end === -1) return raw;
  return raw.slice(end + 4).trim();
}

function countWords(text: string): number {
  const plain = text
    .replace(/\\./g, '')
    .replace(/[#*_~`[\]()]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  return plain ? plain.split(/\s+/).length : 0;
}

function formatReadingTime(words: number): string {
  const minutes = Math.max(1, Math.round(words / WORDS_PER_MINUTE));
  return minutes === 1 ? '1 min read' : `${minutes} min read`;
}

function formatTags(tags?: StoryTags): string {
  if (!tags) return '';
  const items = [...(tags.genre ?? []), ...(tags.themes ?? []), ...(tags.tone ?? [])];
  // shuffle tags
  items.sort(() => Math.random() - 0.5);
  return items.slice(0, 4).join(', ');
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
}

const stories = Object.entries(storyModules)
  .map(([filepath, { frontmatter }]) => {
    const slug = filepath.replace('./stories/', '').replace(/\.md$/, '');
    const raw = storyRawModules[filepath] ?? '';
    const wordCount = countWords(stripFrontmatter(raw));

    return {
      title: frontmatter.title,
      publishDate: frontmatter.publishDate,
      href: `/stories/${slug}/`,
      tagLine: formatTags(frontmatter.tags),
      wordCount,
      readingTime: formatReadingTime(wordCount),
      downloadUrl: frontmatter.downloadUrl,
    };
  })
  .sort(
    (a, b) =>
      new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime()
  );
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A collection of short stories by Tim Graboski" />
    <link
      rel="preload"
      href="/fonts/merriweather-400-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>Stories</title>
  </head>
  <body>
    <main>
      <h1 class="page-title">Stories</h1>
      <ul class="story-list">
        {
          stories.map((story) => (
            <li class="story-list-item">
              <a class="story-list-link" href={story.href}>
                {story.title}
              </a>
              <div class="story-list-details">
                <time
                  class="story-list-date"
                  datetime={story.publishDate}
                >
                  {formatDate(new Date(story.publishDate))}
                </time>
                <span class="story-list-stats">
                  {story.wordCount.toLocaleString()} words
                </span>
                <span class="story-list-stats">
                  {story.readingTime}
                </span>
                {story.downloadUrl && (
                  <a class="story-list-download" href={story.downloadUrl}>
                    Download
                  </a>
                )}
              </div>
              {story.tagLine && (
                <p class="story-list-tags">{story.tagLine}</p>
              )}
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
