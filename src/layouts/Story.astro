---
import Head from '../components/Head.astro';
import StoryFooter from '../components/StoryFooter.astro';
import { formatDate } from '../utils/date';
import '../styles/global.css';

const { frontmatter } = Astro.props;
const title = frontmatter.title ?? 'Story';
const author = frontmatter.author ?? 'Tim Graboski';
const description =
  frontmatter.description ?? `${title} — a short story by ${author}.`;
const subtitle = formatDate(frontmatter.publishDate);
---

<html lang="en">
  <Head title={title} description={description}>
    <meta name="author" content={author} />
  </Head>
  <body>
    <main>
      <article class="story">
        <h1 class="story-title">{title}</h1>
        {subtitle && <h2 class="story-subtitle">{subtitle}</h2>}
        <slot />
        <StoryFooter currentPath={Astro.url.pathname} />
      </article>
    </main>
  </body>
</html>
