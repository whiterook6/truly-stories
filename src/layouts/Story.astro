---
import Head from '../components/Head.astro';
import '../styles/global.css';

const { frontmatter } = Astro.props;
const title = frontmatter.title ?? 'Story';
const author = frontmatter.author ?? 'Tim Graboski';
const description =
  frontmatter.description ?? `${title} — a short story by ${author}.`;
const subtitle = new Date(frontmatter.publishDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<html lang="en">
  <head>
    <Head title={title} description={description} />
  </head>
  <body>
    <main>
      <article class="story">
        <h1 class="story-title">{title}</h1>
        {subtitle && <h2 class="story-subtitle">{subtitle}</h2>}
        <slot />
      </article>
    </main>
  </body>
</html>
